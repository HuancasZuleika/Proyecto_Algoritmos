      <SubComponents>
        <Component class="javax.swing.JTextArea" name="jTextArea1">
          <Properties>
            <Property name="columns" type="int" value="20"/>
            <Property name="lineWrap" type="boolean" value="true"/>
            <Property name="rows" type="int" value="5"/>
            <Property name="text" type="java.lang.String" value="&#xa1;Vamos a resolver un acertijo! Tenemos esta operaci&#xf3;n&#xa;&#xa;Paso 1: El Escudo M&#xe1;gico &#xa;&#xa;Primero resolvemos lo que est&#xe1; protegido por par&#xe9;ntesis: 7&#x2212;4=3. &#xa1;Ahora nuestra operaci&#xf3;n es m&#xe1;s peque&#xf1;a: 5+6&#xf7;3!&#xa;&#xa;Paso 2: La Fuerza de la Divisi&#xf3;n&#xa;Entre sumar y dividir, &#xa1;la divisi&#xf3;n es m&#xe1;s fuerte! As&#xed; que hacemos: 6&#xf7;3=2.&#xa;&#xa;Paso 3: El Gran Final&#xa;Ahora solo nos queda sumar: 5+2=7.&#xa;&#xa;&#xa1;Viste! Si sigues el orden, &#xa1;siempre llegas a la meta!&quot;."/>
            <Property name="wrapStyleWord" type="boolean" value="true"/>
          </Properties>
        </Component>
      </SubComponents>
    </Container>
