      <SubComponents>
        <Component class="javax.swing.JTextArea" name="jTextArea1">
          <Properties>
            <Property name="columns" type="int" value="20"/>
            <Property name="lineWrap" type="boolean" value="true"/>
            <Property name="rows" type="int" value="5"/>
            <Property name="text" type="java.lang.String" value="Vamos a imaginar que los lados de este tri&#xe1;ngulo son piezas de un rompecabezas.&#xa;&#xa;1. Multiplicamos el primer lado por s&#xed; mismo: 3 * 3 = 9.&#xa;&#xa;2. Hacemos lo mismo con el segundo lado: 4 * 4 = 16.&#xa;&#xa;3. &#xa1;Sumamos los resultados!: 9 + 16 = 25.&#xa;&#xa;&#xbf;Qu&#xe9; n&#xfa;mero multiplicado por s&#xed; mismo nos da 25? &#xa;&#xa;&#xa1;La Hipotenusa mide 5 y hemos resuelto el misterio! &quot;"/>
            <Property name="wrapStyleWord" type="boolean" value="true"/>
            <Property name="cursor" type="java.awt.Cursor" editor="org.netbeans.modules.form.editors2.CursorEditor">
              <Color id="Text Cursor"/>
            </Property>
          </Properties>
        </Component>
