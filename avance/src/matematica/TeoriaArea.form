      <SubComponents>
        <Component class="javax.swing.JTextArea" name="jTextArea1">
          <Properties>
            <Property name="columns" type="int" value="20"/>
            <Property name="lineWrap" type="boolean" value="true"/>
            <Property name="rows" type="int" value="5"/>
            <Property name="text" type="java.lang.String" value="&quot;&#xa1;Hola, peque&#xf1;o arquitecto! &#xa;&#xbf;Sab&#xed;as que el &#xc1;REA es el tama&#xf1;o de la superficie de una figura? &#xa;Es decir, todo el espacio que hay dentro de sus l&#xed;neas.&#xa;&#xa;Para cada figura hay una f&#xf3;rmula m&#xe1;gica:&#xa;&#xa;Cuadrado: &#xa1;Solo multiplicas un lado por el otro!&#xa;&#xa;Tri&#xe1;ngulo: Imagina la mitad de un rect&#xe1;ngulo. &#xa1;Es base por altura entre dos!&#xa;&#xa;Rectangulo: &#xa1;Aqui vamos solo a multiplicar el ancho por la altura !&#xa;&#xa;&#xa1;Aprender a medir &#xe1;reas nos ayuda a construir cosas asombrosas!&quot;"/>
            <Property name="wrapStyleWord" type="boolean" value="true"/>
          </Properties>
        </Component>
      </SubComponents>
